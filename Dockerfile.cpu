FROM python:3.12-slim

# CPU-only build for local testing (no CUDA)
RUN pip install --no-cache-dir "numpy<2" "flwr[simulation]>=1.13" scikit-learn pandas pillow \
    torch torchvision --index-url https://download.pytorch.org/whl/cpu

WORKDIR /app
COPY fl_common/ /app/fl_common/
COPY models/ /app/models/
COPY tasks/ /app/tasks/
COPY privacy/ /app/privacy/
COPY experiments/ /app/experiments/
COPY run_tests.py run_all.py /app/

ENV PYTHONUNBUFFERED=1
ENV SYNTHETIC=1
